# Runtime mode. Use production/prod/staging only after replacing all required secrets.
# Production-like modes reject placeholder admin and bot-internal secrets at startup.
APP_ENV=development

DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/fashion_bot
TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/fashion_bot_test
POSTGRES_DB=fashion_bot
POSTGRES_USER=postgres
# Replace the database password outside local development.
POSTGRES_PASSWORD=postgres

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_PUBLIC_URL=http://localhost:8000

ADMIN_FRONTEND_URL=http://localhost:5173

JWT_SECRET=replace_with_strong_admin_jwt_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

TELEGRAM_BOT_TOKEN=put_token_here
BOT_BACKEND_API_URL=http://backend:8000/api
BOT_BACKEND_TIMEOUT_SECONDS=10
BOT_GENERATION_TIMEOUT_SECONDS=180
# Full-photo Telegram try-on stays off until a real clothing mask/segmentation path exists.
BOT_USER_PHOTO_TRY_ON_ENABLED=false
# User-facing garment-crop try-on is disabled: it creates a standalone crop/image, not an edit of the original photo.
BOT_USER_PHOTO_GARMENT_CROP_TRY_ON_ENABLED=false
# Must match in backend and bot containers.
BOT_INTERNAL_TOKEN=change_me_bot_internal_token

OPENAI_API_KEY=put_openai_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1536
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_OUTPUT_FORMAT=png
OPENAI_IMAGE_TIMEOUT_SECONDS=120

# Optional user-photo clothing edit mask pipeline.
# Strict production-quality clothing-only edits require a mask by default.
# Modes: off, provided, mock, provider. provider is reserved for a future segmentation integration.
# Keep USER_PHOTO_REQUIRE_MASK_FOR_STRICT_EDIT=true outside explicit local/dev legacy testing.
# If set false with USER_PHOTO_MASK_MODE=off, no-mask edit is unsafe and can alter face/background.
USER_PHOTO_MASK_MODE=off
USER_PHOTO_REQUIRE_MASK_FOR_STRICT_EDIT=true
USER_PHOTO_MASK_MIN_COVERAGE_PERCENT=3
USER_PHOTO_MASK_MAX_COVERAGE_PERCENT=80
USER_PHOTO_MASK_DILATE_PIXELS=0
USER_PHOTO_MASK_DEBUG_SAVE=false
# Post-generation preservation guardrail for masked user-photo edits.
# Provider outputs that change protected pixels outside the transparent mask fail closed.
USER_PHOTO_PRESERVATION_CHECK_ENABLED=true
USER_PHOTO_PRESERVATION_MAX_MEAN_DELTA=1
USER_PHOTO_PRESERVATION_MAX_CHANGED_PIXEL_PERCENT=1
USER_PHOTO_PRESERVATION_PIXEL_DELTA_THRESHOLD=8
TRYON_PROVIDER_STRATEGY=chatgpt_like_masked_edit
TRYON_MAX_PROVIDER_ATTEMPTS=1
TRYON_DEBUG_BUNDLE_ENABLED=false

# Internal crop-only operator review smoke. Keep false unless a fresh explicit Track A GO is recorded.
# This route is fake-provider only and must not be used as user-facing rollout approval.
CROP_ONLY_OPERATOR_REVIEW_TRACK_A_ENABLED=false

UPLOAD_DIR=/app/uploads
# MAX_UPLOAD_BYTES takes precedence over MAX_UPLOAD_SIZE_MB when set.
MAX_UPLOAD_SIZE_MB=10
MAX_UPLOAD_BYTES=10485760

# Simple in-memory abuse guards. Set a limit to 0 only for local debugging.
RATE_LIMIT_WINDOW_SECONDS=60
ADMIN_LOGIN_RATE_LIMIT=60
BOT_API_RATE_LIMIT=120
GENERATION_RATE_LIMIT=10
UPLOAD_RATE_LIMIT=30

INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=replace_with_strong_admin_password

# Development-only demo seed. Keep false for production/prod/staging.
SEED_DEMO_DATA=false

VITE_API_BASE_URL=http://localhost:8000/api
VITE_BACKEND_PUBLIC_URL=http://localhost:8000
