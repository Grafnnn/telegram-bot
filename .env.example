# Runtime mode. production/prod/staging reject placeholder admin secrets.
APP_ENV=development

DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/fashion_bot
TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/fashion_bot_test
POSTGRES_DB=fashion_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_PUBLIC_URL=http://localhost:8000

ADMIN_FRONTEND_URL=http://localhost:5173

JWT_SECRET=replace_with_strong_admin_jwt_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

TELEGRAM_BOT_TOKEN=put_token_here
BOT_BACKEND_API_URL=http://backend:8000/api
BOT_INTERNAL_TOKEN=change_me_bot_internal_token

OPENAI_API_KEY=put_openai_key_here
OPENAI_MODEL=gpt-4o-mini

UPLOAD_DIR=/app/uploads
# MAX_UPLOAD_BYTES takes precedence over MAX_UPLOAD_SIZE_MB when set.
MAX_UPLOAD_SIZE_MB=10
MAX_UPLOAD_BYTES=10485760

INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=replace_with_strong_admin_password

SEED_DEMO_DATA=false

VITE_API_BASE_URL=http://localhost:8000/api
VITE_BACKEND_PUBLIC_URL=http://localhost:8000
